# AIAssist Settings Web App — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google Analytics 4 — Web data stream Measurement ID (Admin → Data streams → Web → Measurement ID)
# Must match the property you open in analytics.google.com or realtime will stay empty.
VITE_GA_MEASUREMENT_ID=G-T3T0N5C7YG

# Job Search API (RapidAPI JSearch)
# Get a free key at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
VITE_RAPIDAPI_KEY=your-rapidapi-key-here

# OpenRouter API (for AI Resume Builder)
# Get a free key at: https://openrouter.ai/keys (free models available)
VITE_OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
